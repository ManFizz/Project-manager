@model IEnumerable<MegaProject.Models.Employee>
@{
ViewData["Title"] = "Employees";
}

<div class="container mt-4">
    <h2>Employees</h2>
    <a asp-action="Create" class="btn btn-success mb-3">+ Add New Employee</a>

    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var employee in Model)
        {
        <tr>
            <td>@employee.FirstName @employee.MiddleName @employee.LastName</td>
            <td>@employee.Mail</td>
            <td>
                <a asp-action="Edit" asp-route-id="@employee.Id" class="btn btn-sm btn-primary">Edit</a>
                <form asp-action="Delete" asp-route-id="@employee.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-danger"
                            onclick="return confirm('Are you sure you want to delete this employee?')">
                        Delete
                    </button>
                </form>
            </td>
        </tr>
        }
        </tbody>
    </table>
</div>