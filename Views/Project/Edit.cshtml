@model MegaProject.Models.Project
@{
ViewData["Title"] = "Edit Project";
}

<div class="container mt-5">
    <h2>Edit Project "@Model.Name"</h2>
    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id"/>

        <div class="mb-3">
            <label>Project Name</label>
            <input asp-for="Name" class="form-control"/>
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Customer Company</label>
            <input asp-for="ClientName" class="form-control"/>
            <span asp-validation-for="ClientName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Executor Company</label>
            <input asp-for="ExecutorName" class="form-control"/>
            <span asp-validation-for="ExecutorName" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Start Date</label>
            <input asp-for="Start" type="date" class="form-control"/>
            <span asp-validation-for="Start" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>End Date</label>
            <input asp-for="End" type="date" class="form-control"/>
            <span asp-validation-for="End" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label>Priority</label>
            <input asp-for="Priority" type="number" class="form-control"/>
            <span asp-validation-for="Priority" class="text-danger"></span>
        </div>
        
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        
        <h4 class="mt-4">Project Documents</h4>

        <h5>Add New Files</h5>
        <div id="drop-zone" class="border border-2 border-dashed p-4 text-center mb-3">
            Drop files here or <strong>click</strong>
            <input type="file" id="file-input" name="files" multiple style="display:none;" />
            <span asp-validation-for="DocumentPaths" class="text-danger"></span>
        </div>
        <div id="upload-errors"></div>
        <div id="file-list" class="list-group mb-3"></div>
    </form>
    <div class="list-group mb-3">
        @foreach (var file in Model.DocumentPaths)
        {
        <div class="list-group-item d-flex justify-content-between align-items-center">
            <a href="@file" target="_blank">
                @System.IO.Path.GetFileName(file)
            </a>

            <form asp-action="DeleteFile" method="post" style="display:inline;" >
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="filePath" value="@file" />
                <button type="submit" class="btn btn-sm btn-danger">
                    Delete
                </button>
            </form>
        </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/uploader/uploader.js"></script>
    <script src="~/js/uploader/uploader-ui.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initUploader();
        });
    </script>
}