@model IEnumerable<MegaProject.Models.Project>
@{
ViewData["Title"] = "Projects";
}

<div class="container mt-4">
    <h2>Projects</h2>
    <a asp-action="Create" class="btn btn-success mb-3">+ Add New Project</a>

    <table class="table table-striped">
        <thead>
        <tr>
            <th>Name</th>
            <th>Client name</th>
            <th>Executor name</th>
            <th>Manager</th>
            <th>Date of start</th>
            <th>Date of end</th>
            <th>Priority</th>
            <th>Documents</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var project in Model)
        {
        <tr>
            <td>@project.Name</td>
            <td>@project.ClientName</td>
            <td>@project.ExecutorName</td>
            <td>@project.Manager!.FirstName @project.Manager.MiddleName @project.Manager.LastName</td>
            <td>@project.Start</td>
            <td>@project.End</td>
            <td>@project.Priority</td>
            <td>@project.DocumentPaths.Count</td>
        </tr>
        }
        </tbody>
    </table>
</div>